{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ChanceTime",
  "version": "0.1.0",
  "identifier": "com.chancetime.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Chance Time",
        "width": 1024,
        "height": 720,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; frame-src http://127.0.0.1:8787 http://localhost:8787; connect-src 'self' http://127.0.0.1:8787 http://localhost:8787; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Chance Time trading desktop shell",
    "longDescription": "Local control plane for the Chance Time paper-first prediction-market bot (Kalshi / Polymarket US)."
  }
}
