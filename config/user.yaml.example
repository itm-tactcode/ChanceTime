# Copy to config/user.yaml (gitignored) for personal non-secret overrides.
# Desktop Settings tab / `chancetime user-config apply` / POST /api/user-config write here.
# Never put API keys in this file.
#
#   cp config/user.yaml.example config/user.yaml
#
# Merge order: --config path  <  config/user.yaml  <  secrets in .env

