# =============================================================================
# Chance Time — secrets only (copy to .env). NEVER commit .env or secrets/*.
#
# Non-secret knobs (poll interval, risk, strategies) → config/*.yaml or
# config/user.yaml (see config/user.yaml.example). Dashboard will edit user.yaml.
# =============================================================================

# --- Safety ---
# Default true. Live requires CLI risk-ack; never flip casually.
PAPER_MODE=true

# --- Grok / xAI ---
# https://console.x.ai
XAI_API_KEY=

# --- Kalshi ---
# https://docs.kalshi.com/getting_started/api_keys
# Demo keys (demo.kalshi.co) ≠ prod keys (kalshi.com)
KALSHI_API_KEY=
KALSHI_PRIVATE_KEY_PATH=./secrets/kalshi.key
KALSHI_ENV=prod

# --- Polymarket US (not polymarket.com international) ---
# https://polymarket.us/developer — base64 Ed25519 secret file
POLYMARKET_API_KEY=
POLYMARKET_PRIVATE_KEY_PATH=./secrets/polymarket.key

# --- Optional Telegram alerts ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Optional / legacy (prefer config/user.yaml instead) ---
# POLL_INTERVAL_SECONDS=30
# GROK_MODEL=grok-4.5
# LLM_DAILY_BUDGET_USD=5.0
# LOG_LEVEL=INFO
# MAX_POSITION_USD=50
# MAX_DAILY_LOSS_USD=25
# MAX_OPEN_POSITIONS=10
# CONFIG_PATH=config/default.yaml
